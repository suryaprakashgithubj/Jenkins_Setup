pipeline {
    agent any

    tools {
        maven 'Maven installations'
    }

    stages {

        stage('Clean') {
            steps {
                dir('prameworkcucutest') {
                    sh 'mvn clean'
                }
            }
        }

        stage('Test') {
            steps {
                dir('prameworkcucutest') {
                    sh 'mvn test'
                }
            }
        }
    }

    post {

        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }
    }
}