pipeline {
    agent any

    tools {
        maven 'Maven installations'
    }

    stages {

        stage('Clean') {
            steps {
                dir('prameworkcucutest') {
                    sh 'mvn clean'
                }
            }
        }

        stage('Test') {
            steps {
                dir('prameworkcucutest') {
                    sh 'mvn test'
                }
            }
        }
    }

    post {

        success {
            echo 'Build Successful'

            emailext(
                subject: "Jenkins Build Success - ${env.JOB_NAME}",
                body: """
                Build Successful

                Job Name: ${env.JOB_NAME}
                Build Number: ${env.BUILD_NUMBER}
                Build URL: ${env.BUILD_URL}
                """,
                to: 'suryaprakashj32@gmail.com'
            )
        }

        failure {
            echo 'Build Failed'

            emailext(
                subject: "Jenkins Build Failed - ${env.JOB_NAME}",
                body: """
                Build Failed

                Job Name: ${env.JOB_NAME}
                Build Number: ${env.BUILD_NUMBER}
                Build URL: ${env.BUILD_URL}
                """,
                to: 'suryaprakashj32@gmail.com'
            )
        }
    }
}