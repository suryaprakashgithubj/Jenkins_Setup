pipeline {
    agent any

    environment {
        DOCKER = '/usr/local/bin/docker'
        SELENIUM_URL = 'http://selenium-chrome:4444'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Pankajvis1/Wipro_Selenium_Training.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '${DOCKER} build -t cucumber-framework .'
            }
        }

        stage('Create Network') {
            steps {
                sh '${DOCKER} network create selenium-net || true'
            }
        }

        stage('Start Selenium') {
            steps {
                sh '''
                ${DOCKER} rm -f selenium-chrome || true

                ${DOCKER} run -d \
                --name selenium-chrome \
                --network selenium-net \
                -p 4444:4444 \
                selenium/standalone-chrome
                '''

                sh 'sleep 15'
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                ${DOCKER} run --rm \
                --network selenium-net \
                cucumber-framework \
                mvn test \
                -Dtest=Runner.RunCucumberTest \
                -Dselenium.remote.url=http://selenium-chrome:4444
                '''
             }
        }
    }

    post {
        always {
            sh '${DOCKER} rm -f selenium-chrome || true'
        }
        success {
            echo "BUILD SUCCESS"
        }
        failure {
            echo "BUILD FAILED"
        }
    }
}